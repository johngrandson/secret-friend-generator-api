POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SERVER=
POSTGRES_PORT=
POSTGRES_DB=

DATABASE_URL=

PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
MCP_SERVERS_PATH=

# Celery / RabbitMQ
# CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# CELERY_RESULT_BACKEND=rpc://
# CELERY_TASK_ALWAYS_EAGER=false

# Run event bus (real-time SSE stream for /runs/{id}/stream). When unset the
# bus is a no-op and the SSE endpoint closes immediately. In dev point at the
# same Redis as Celery, e.g.: REDIS_URL=redis://localhost:6380/0
# REDIS_URL=

# RabbitMQ queue type: classic (default) or quorum (requires 3-node cluster)
# CELERY_QUEUE_TYPE=classic

# Extra queues to declare beyond "default". Comma-separated.
# CELERY_EXTRA_QUEUES=notifications,heavy

# Task routing: JSON object mapping task pattern -> queue name.
# CELERY_TASK_ROUTES={"notifications.*": "notifications", "heavy.*": "heavy"}

# Recommended worker pool — pass as --pool flag when starting the worker.
# prefork (default) | threads | gevent | solo
# CELERY_WORKER_POOL=prefork

# Symphony pipeline — points to the active WORKFLOW.md (one project per worker).
# The workflow front matter pulls Linear creds via $LINEAR_API_KEY / $LINEAR_PROJECT_SLUG.
SYMPHONY_WORKFLOW_PATH=workflows/skaffold.md

# Linear — referenced from the workflow front matter (tracker.api_key / project_slug).
# project_slug is the Linear "slugId" (short hash in the project URL: linear.app/<team>/project/<slug>-<slugId>).
LINEAR_API_KEY=
LINEAR_PROJECT_SLUG=